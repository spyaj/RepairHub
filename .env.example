# Core app
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Admin seed credentials (manual admin account created by prisma/seed.ts)
ADMIN_SEED_EMAIL=admin@repairhub.local
ADMIN_SEED_PASSWORD=replace_with_admin_password
# MongoDB (current local auth store)
# Local default
MONGODB_URL=mongodb://127.0.0.1:27017/repairhub
# Auth (NextAuth option)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_random_secret
NEXTAUTH_URL=http://localhost:3000



#Below not needed for now, can be added later when integrating those services. Just keep the keys here as placeholders for now to avoid confusion.
#-------------------------------------------------------------------------------------------------#
# Database (Supabase Postgres or local Postgres)
# Get from Supabase project: Project Settings -> Database -> Connection string
#DATABASE_URL=postgresql://postgres:password@localhost:5432/repairhub?schema=public



GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# Supabase (database hosting only in this stack)
# Optional if you later use Supabase services beyond DB
#NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
#SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# AI provider - choose one primary free tier
# Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_with_gemini_api_key

# Optional fallback AI provider
# Hugging Face token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=replace_with_huggingface_token

# Maps / geocoding
# OSM/Nominatim is the primary free option and does not require a key.
# Keep an optional fallback key only when needed.
OPENCAGE_API_KEY=replace_with_opencage_key

# Payments (Stripe test mode only for demo)
# Keys from Stripe dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Email notifications (optional)
# Resend key: https://resend.com/api-keys
RESEND_API_KEY=re_replace_me
EMAIL_FROM=noreply@repairhub.local



# File storage (if using Cloudinary)
# Cloudinary console: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Logging/monitoring (optional)
# Sentry DSN: https://sentry.io/settings/projects/
SENTRY_DSN=replace_with_sentry_dsn
